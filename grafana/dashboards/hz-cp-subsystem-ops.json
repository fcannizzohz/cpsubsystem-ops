        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (name) (hz_raft_group_commitIndex{mc_cluster=\"$cluster\", name=~\"$cp_group\"})",
          "legendFormat": "commitIndex \u2013 {{name}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (name) (hz_raft_group_lastApplied{mc_cluster=\"$cluster\", name=~\"$cp_group\"})",
          "legendFormat": "lastApplied \u2013 {{name}}",
          "refId": "B"
