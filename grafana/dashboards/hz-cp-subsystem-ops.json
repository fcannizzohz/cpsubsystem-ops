    {
      "id": 11,
      "type": "timeseries",
      "title": "Commit Index vs Last Applied (per group)",
      "description": "commitIndex leads lastApplied. A persistent gap indicates replication lag \u2014 entries committed by the leader but not yet applied by followers.",
