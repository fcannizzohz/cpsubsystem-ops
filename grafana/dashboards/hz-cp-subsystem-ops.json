    {
      "id": 32,
      "type": "timeseries",
      "title": "Semaphore Available Permits",
      "description": "Available permits per semaphore. Drops to 0 = resource starvation / all permits acquired. Requires ISemaphore usage.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 49,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
