        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
