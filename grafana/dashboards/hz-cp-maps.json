    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "Commit Lag per Group",
      "description": "Replication lag for the groups holding maps. A lag spike here means CPMap reads on followers may return slightly stale data (if using relaxed consistency).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 40,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hz_raft_group_commitIndex{mc_cluster=\"$cluster\", name=~\"$cp_group\"} - hz_raft_group_lastApplied{mc_cluster=\"$cluster\", name=~\"$cp_group\"}",
          "legendFormat": "{{name}} @ {{mc_member}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
