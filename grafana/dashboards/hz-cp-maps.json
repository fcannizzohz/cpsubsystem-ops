      "gridPos": {
        "x": 0,
        "y": 40,
        "w": 12,
        "h": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(hz_raft_group_commitIndex{mc_cluster=\"$cluster\", name=~\"$cp_group\"}[1m])",
          "legendFormat": "{{name}} @ {{mc_member}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6
          },
