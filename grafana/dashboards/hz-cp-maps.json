    {
      "id": 7,
      "type": "timeseries",
      "title": "CP Map Lifecycle (live vs destroyed)",
      "description": "Trends of live and destroyed CPMaps per CP group. Live count should be stable once maps are initialised. A rising destroyed count means maps are being re-created \u2014 each creation generates Raft log entries.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 6
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(hz_cp_map_summary_live_count{mc_cluster=\"$cluster\"}) by (group)",
          "legendFormat": "live \u2013 {{group}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max(hz_cp_map_summary_destroyed_count{mc_cluster=\"$cluster\"}) by (group)",
          "legendFormat": "destroyed \u2013 {{group}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 6
          },
          "min": 0,
          "unit": "short"
        },
        "overrides": []
      }
    },
