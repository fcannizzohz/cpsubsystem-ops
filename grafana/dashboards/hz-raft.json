            "lineWidth": 2,
            "fillOpacity": 6
          },
          "min": 0,
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Commit Lag (commitIndex \u2212 lastApplied)",
      "description": "Entries committed by the leader but not yet applied by this member. Should stay near 0. A growing lag on a follower indicates it is falling behind.",
