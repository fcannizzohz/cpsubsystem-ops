            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "hz_raft_group_lastLogIndex{mc_cluster=\"$cluster\", name=~\"$cp_group\"} - hz_raft_group_commitIndex{mc_cluster=\"$cluster\", name=~\"$cp_group\"}",
          "legendFormat": "{{name}} / {{mc_member}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
