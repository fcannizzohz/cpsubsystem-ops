      "type": "timeseries",
      "title": "Session Heartbeat Rate",
      "description": "Rate of CP session heartbeat increments per second (derived from hz_cp_session_version). A healthy session heartbeats every 5 s (\u2248 0.2 hz). Rate dropping to 0 means the client has stopped heartbeating \u2014 the session will expire in \u2264 60 s (session-time-to-live), releasing any FencedLocks or ISemaphore permits it holds.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 68,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rate(hz_cp_session_version{mc_cluster=\"$cluster\"}[30s])",
          "legendFormat": "session {{id}} / {{mc_member}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
