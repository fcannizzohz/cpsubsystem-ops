          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "clamp_min(hz_cp_semaphore_available{mc_cluster=\"$cluster\"} == 0, 1)",
          "legendFormat": "{{name}} drained",
          "refId": "A"
