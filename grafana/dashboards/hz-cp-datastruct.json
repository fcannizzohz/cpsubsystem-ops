    {
      "id": 20,
      "type": "timeseries",
      "title": "Permit Utilisation Ratio",
      "description": "Fraction of permits currently in use: (max_observed \u2212 available) / max_observed. 0 = all permits free, 1 = all permits acquired (pool exhausted). Uses the 1-hour observed maximum as the denominator \u2014 accurate once the semaphore has been fully acquired at least once.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "1 - (hz_cp_semaphore_available{mc_cluster=\"$cluster\"} / clamp_min(max_over_time(hz_cp_semaphore_available{mc_cluster=\"$cluster\"}[1h]), 1))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max",
            "mean"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.95
              }
            ]
          }
        },
        "overrides": []
      }
    },
